{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "target": "ES2020",
    "module": "CommonJS", // tetap pakai CommonJS (lebih aman untuk Node + Jest)
    "moduleResolution": "Node",
    "esModuleInterop": true, // ✅ penting untuk import default dari modul CommonJS
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,

    "types": ["node"],
    "strict": true,
    "sourceMap": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}
